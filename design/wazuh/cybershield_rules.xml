<!-- ============================================= -->
<!-- CyberShield Custom Rules for Wazuh            -->
<!-- Proyecto TFG - Detección de ataques de red    -->
<!--                                               -->
<!-- DEPLOYMENT: Copiar a /var/ossec/etc/rules/     -->
<!-- en el WAZUH MANAGER (no en el agente)          -->
<!-- ============================================= -->

<group name="cybershield,attack,">

  <!-- ==========================================
       REGLA BASE: Cualquier evento SEC_VIOLATION
       ========================================== -->
  <rule id="100100" level="10">
    <decoded_as>cybershield</decoded_as>
    <match>SEC_VIOLATION</match>
    <description>CyberShield: Security violation detected - $(attack_type)</description>
    <group>cybershield,network_attack,</group>
  </rule>

  <!-- ==========================================
       MAC FLOODING — T1557
       Nivel 14 (Crítico)
       ========================================== -->
  <rule id="100101" level="14">
    <if_sid>100100</if_sid>
    <match>MAC Flooding</match>
    <description>CyberShield CRITICAL: MAC Flooding Attack - CAM Table Overflow on $(interface) - $(packet_count) packets sent via $(port_info)</description>
    <mitre>
      <id>T1557</id>
    </mitre>
    <group>cybershield,mac_flooding,critical,</group>
  </rule>

  <!-- ==========================================
       ARP SPOOFING — T1557.002
       Nivel 13 (Alto)
       ========================================== -->
  <rule id="100102" level="13">
    <if_sid>100100</if_sid>
    <match>ARP Spoofing</match>
    <description>CyberShield HIGH: ARP Spoofing Attack detected on $(interface) - MITM via ARP Cache Poisoning</description>
    <mitre>
      <id>T1557.002</id>
    </mitre>
    <group>cybershield,arp_spoofing,high,</group>
  </rule>

  <!-- ==========================================
       VLAN HOPPING — T1599.001
       Nivel 13 (Alto)
       ========================================== -->
  <rule id="100103" level="13">
    <if_sid>100100</if_sid>
    <match>VLAN Hopping</match>
    <description>CyberShield HIGH: VLAN Hopping Attack detected on $(interface) - DTP/802.1Q exploitation</description>
    <mitre>
      <id>T1599.001</id>
    </mitre>
    <group>cybershield,vlan_hopping,high,</group>
  </rule>

  <!-- ==========================================
       STP ATTACK — T1557
       Nivel 12 (Alto)
       ========================================== -->
  <rule id="100104" level="12">
    <if_sid>100100</if_sid>
    <match>STP Attack</match>
    <description>CyberShield HIGH: STP Root Bridge Attack detected on $(interface)</description>
    <mitre>
      <id>T1557</id>
    </mitre>
    <group>cybershield,stp_attack,high,</group>
  </rule>

  <!-- ==========================================
       DHCP STARVATION — T1557
       Nivel 12 (Alto)
       ========================================== -->
  <rule id="100105" level="12">
    <if_sid>100100</if_sid>
    <match>DHCP Starvation</match>
    <description>CyberShield HIGH: DHCP Starvation Attack detected on $(interface) - Pool exhaustion</description>
    <mitre>
      <id>T1557</id>
    </mitre>
    <group>cybershield,dhcp_starvation,high,</group>
  </rule>

  <!-- ==========================================
       DNS SPOOFING — T1557.001 (futuro)
       Nivel 13 (Alto)
       ========================================== -->
  <rule id="100106" level="13">
    <if_sid>100100</if_sid>
    <match>DNS Spoofing</match>
    <description>CyberShield HIGH: DNS Spoofing Attack detected on $(interface) - DNS resolution hijack</description>
    <mitre>
      <id>T1071.004</id>
    </mitre>
    <group>cybershield,dns_spoofing,high,</group>
  </rule>

  <!-- ==========================================
       ALERTA DE FRECUENCIA: Múltiples ataques
       Se dispara si 3+ eventos CyberShield en 5 min
       ========================================== -->
  <rule id="100110" level="15" frequency="3" timeframe="300">
    <if_matched_group>cybershield</if_matched_group>
    <description>CyberShield ALERT: Multiple attack events detected in 5 minutes - Active penetration test in progress</description>
    <group>cybershield,multiple_attacks,critical,</group>
  </rule>

</group>
