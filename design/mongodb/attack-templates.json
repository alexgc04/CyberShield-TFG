[
    {
        "name": "MAC Flooding",
        "module": "network-audit",
        "mitre_id": "T1557",
        "command_base": "sudo macof -i {{interface}} -n {{count}}",
        "params": {
            "interface": "eth0",
            "count": "5000"
        },
        "post_attack_notify": "logger -t CyberShield -p local0.alert 'SEC_VIOLATION: MAC Flooding detected on Port 1 - Interface {{interface}} - {{count}} packets sent - CAM Table Overflow confirmed - MITRE:T1557'",
        "status": "validated",
        "validated_on": "2026-05-08",
        "notes": "tun0 (VPN L3) filtra tráfico L2. Validado con éxito sobre eth0 (bridge VirtualBox). Tabla CAM saturada confirmada."
    },
    {
        "name": "ARP Spoofing",
        "module": "network-audit",
        "mitre_id": "T1557.002",
        "command_base": "sudo bettercap -iface {{interface}} -eval \"set arp.spoof.targets {{target}}; arp.spoof on\"",
        "params": {
            "interface": "tun0",
            "target": "10.10.10.X"
        },
        "status": "pending"
    },
    {
