<?xml version="1.0" encoding="UTF-8"?>
<!-- ============================================================
     CyberShield – Decoders para Wazuh
     Parsea entradas syslog con programa "CyberShield"
     y extrae campos de los mensajes SEC_VIOLATION.
     ============================================================ -->

<decoder name="cybershield">
  <program_name>CyberShield</program_name>
</decoder>

<decoder name="cybershield-sec-violation">
  <parent>cybershield</parent>
  <prematch>SEC_VIOLATION:</prematch>
  <regex>SEC_VIOLATION: (\S+) (\S+) (.+) - MITRE:(\S+)</regex>
  <order>attack_type,interface,extra_info,mitre_id</order>
</decoder>
